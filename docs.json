{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Sasini App",
  "logo": {
    "dark": "/logo/sasini-text-logo.svg",
    "light": "/logo/sasini-text-logo.svg",
    "href": "https://sasini.co.ke"
  },
  "colors": {
    "primary": "#76BD22",
    "light": "#A3E635",
    "dark": "#76BD22"
  },
  "modeToggle": {
    "default": "dark",
    "isHidden": "true"
  },
  "favicon": "/favicon.svg",
  "navbar": {
    "links": [
      {
        "label": "Sasini Website",
        "href": "https://sasini.co.ke"
      },
      {
        "label": "Help & Support",
        "href": "/support/settings"
      }
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/sasiniplc",
      "instagram": "https://www.instagram.com/sasiniplc/?hl=en",
      "facebook": "https://www.facebook.com/SasiniTeaandCoffee",
      "linkedin": "https://ke.linkedin.com/company/sasini-plc",
      "youtube": "https://www.youtube.com/channel/UCtwz5m5FWhxy-qub0N5F-MQ"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "System Users",
        "groups": [
          {
            "group": "System Overview",
            "pages": [
              "index"
            ]
          },
          {
            "group": "Getting Started",
            "pages": [
              "getting-started/profile"
            ]
          },
          {
            "group": "Produce & Financials",
            "pages": [
              "produce/deliveries",
              "produce/payments"
            ]
          },
          {
            "group": "Farm Management Logistics",
            "pages": [
              "farm/inputs",
              "farm/pickups",
              "farm/pests"
            ]
          },
          {
            "group": "AI, Insights & Weather",
            "pages": [
              "info/sasini-ai",
              "info/weather",
              "info/news-markets"
            ]
          },
          {
            "group": "Account & Support",
            "pages": [
              "support/settings",
              "resources/externals"
            ]
          }
        ]
      }
    ]
  },
  "appearance": {
    "strict": true,
    "default": "dark"
  },
  "styling": {
    "codeblocks": "dark"
  }
}
